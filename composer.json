{
    "name": "softkultur/module-delayed-queue-messages",
    "description": "Allows publishing queue messages with a delay",
    "type": "magento2-module",
    "require": {
        "php": "^8.1",
        "magento/framework": "~103.0.6",
        "psr/log": "^2 || ^3",
        "magento/framework-message-queue": "~100.4.6"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.9",
        "phpunit/phpunit": "^9.6 || ^10.5 || ^11.0",
        "magento/magento-coding-standard": "*",
        "bitexpert/phpstan-magento": "^0.32.0"
    },
    "license": "MIT",
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "SoftKultur\\DelayedQueueMessages\\": "src/"
        }
    },
    "keywords": [
        "magento 2",
        "softkultur",
        "magento 2 queue"
    ],
    "authors": [
        {
            "name": "SoftKultur",
            "email": "office@softkultur.com",
            "homepage": "https://www.softkultur.com",
            "role": "Technical Developer"
        }
    ],
    "repositories": [
        {
            "type": "composer",
            "url": "https://mirror.mage-os.org/",
            "only": [
                "magento/*"
            ]
        }
    ],
    "config": {
        "allow-plugins": {
            "magento/composer-dependency-version-audit-plugin": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "phpstan": "phpstan",
        "phpcs": "vendor/bin/phpcs src/ --standard=./vendor/magento/magento-coding-standard/Magento2/ruleset.xml",
        "phpcs-fix": "vendor/bin/phpcbf src/ --standard=./vendor/magento/magento-coding-standard/Magento2/ruleset.xml",
        "phpunit": "vendor/bin/phpunit"
    }
}
